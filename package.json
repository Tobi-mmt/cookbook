{
	"name": "cookbook-svelte",
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": "24"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --ignore-path .gitignore --check . && eslint --ignore-pattern '.gitignore' .",
		"format": "prettier --ignore-path .gitignore --write . && eslint --ignore-pattern '.gitignore' --fix .",
		"e2e": "cypress run",
		"test": "vitest",
		"get-random-id": "echo $RANDOM | md5 | head -c 15; echo;",
		"get-thumbnail": "node ./scripts/getThumbnail.js",
		"prepare": "husky && svelte-kit sync"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@sveltejs/adapter-vercel": "6.3.3",
		"@sveltejs/enhanced-img": "^0.10.0",
		"@sveltejs/kit": "2.63.0",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@typescript-eslint/eslint-plugin": "8.61.0",
		"@typescript-eslint/parser": "8.61.0",
		"cypress": "15.17.0",
		"eslint": "10.4.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.19.0",
		"globals": "17.6.0",
		"husky": "9.1.7",
		"lint-staged": "17.0.7",
		"prettier": "3.8.4",
		"prettier-plugin-svelte": "3.5.2",
		"svelte": "5.56.2",
		"svelte-check": "4.6.0",
		"tslib": "2.8.1",
		"typescript": "6.0.3",
		"typescript-eslint": "8.61.0",
		"vite": "8.0.16",
		"vitest": "4.1.8"
	},
	"husky": {
		"hooks": {
			"pre-commit": "lint-staged"
		}
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,svelte,json,md,html}": "yarn format"
	},
	"dependencies": {
		"@vercel/analytics": "2.0.1",
		"fuse.js": "7.4.2",
		"sharp": "^0.34.0"
	},
	"packageManager": "yarn@1.22.22"
}
